{
  "name": "@rspack-devtools/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "DevTools UI for Rspack - Shared components and design system",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./unocss": {
      "types": "./src/unocss/index.ts",
      "import": "./src/unocss/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*.vue",
      "import": "./src/components/*.vue"
    },
    "./composables/*": {
      "types": "./src/composables/*.ts",
      "import": "./src/composables/*.ts"
    },
    "./utils/*": {
      "types": "./src/utils/*.ts",
      "import": "./src/utils/*.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "peerDependencies": {
    "@vueuse/core": "*",
    "unocss": "*",
    "vue": "*",
    "vue-virtual-scroller": ">=2.0.0-beta.0"
  }
}
