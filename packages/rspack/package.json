{
  "name": "@rspack-devtools/rspack",
  "version": "0.0.1",
  "type": "module",
  "description": "DevTools for Rspack - Build analysis plugin and UI",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dirs": {
      "import": "./dist/dirs.js",
      "types": "./dist/dirs.d.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "client"
  ],
  "scripts": {
    "build": "pnpm build:client && tsup",
    "build:client": "vite build",
    "dev": "vite",
    "dev:node": "tsup --watch"
  },
  "dependencies": {
    "@rspack-devtools/kit": "workspace:*",
    "@rspack-devtools/rpc": "workspace:*",
    "birpc": "^2.3.0",
    "launch-editor": "^2.9.1",
    "tinyglobby": "^0.2.15"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.0.0",
    "@unocss/reset": "^66.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "d3": "^7.9.0",
    "fuse.js": "^7.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "unocss": "^66.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  }
}
