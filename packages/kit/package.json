{
  "name": "@rspack-devtools/kit",
  "version": "0.0.1",
  "type": "module",
  "description": "DevTools Kit for Rspack - API for building DevTools integrations",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./utils/events": {
      "import": "./dist/utils/events.js",
      "types": "./dist/utils/events.d.ts"
    },
    "./utils/nanoid": {
      "import": "./dist/utils/nanoid.js",
      "types": "./dist/utils/nanoid.d.ts"
    },
    "./constants": {
      "import": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "birpc": "^2.3.0",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@rspack/core": "^1.3.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  }
}
