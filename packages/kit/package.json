{
  "name": "@rspack-devtools/kit",
  "version": "0.0.1",
  "type": "module",
  "description": "DevTools Kit for Rspack - API for building DevTools integrations",
  "license": "MIT",
  "author": "wzc520pyfm",
  "repository": {
    "type": "git",
    "url": "https://github.com/wzc520pyfm/rsdevtools",
    "directory": "packages/kit"
  },
  "homepage": "https://github.com/wzc520pyfm/rsdevtools/tree/main/packages/kit#readme",
  "bugs": "https://github.com/wzc520pyfm/rsdevtools/issues",
  "keywords": ["rspack", "devtools", "kit", "api"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./utils/events": {
      "types": "./dist/utils/events.d.ts",
      "import": "./dist/utils/events.js",
      "require": "./dist/utils/events.cjs"
    },
    "./utils/nanoid": {
      "types": "./dist/utils/nanoid.d.ts",
      "import": "./dist/utils/nanoid.js",
      "require": "./dist/utils/nanoid.cjs"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js",
      "require": "./dist/constants.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@rspack-devtools/rpc": "workspace:*",
    "birpc": "^2.3.0",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@rspack/core": "^1.3.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  }
}
