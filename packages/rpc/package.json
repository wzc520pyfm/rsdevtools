{
  "name": "@rspack-devtools/rpc",
  "version": "0.0.1",
  "type": "module",
  "description": "DevTools RPC Layer for Rspack",
  "license": "MIT",
  "author": "wzc520pyfm",
  "repository": {
    "type": "git",
    "url": "https://github.com/wzc520pyfm/rsdevtools",
    "directory": "packages/rpc"
  },
  "homepage": "https://github.com/wzc520pyfm/rsdevtools/tree/main/packages/rpc#readme",
  "bugs": "https://github.com/wzc520pyfm/rsdevtools/issues",
  "keywords": ["rspack", "devtools", "rpc", "birpc"],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "import": "./dist/presets/index.js",
      "require": "./dist/presets/index.cjs"
    },
    "./presets/ws/client": {
      "types": "./dist/presets/ws/client.d.ts",
      "import": "./dist/presets/ws/client.js",
      "require": "./dist/presets/ws/client.cjs"
    },
    "./presets/ws/server": {
      "types": "./dist/presets/ws/server.d.ts",
      "import": "./dist/presets/ws/server.js",
      "require": "./dist/presets/ws/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "ws": "*"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "dependencies": {
    "birpc": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.14",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "ws": "^8.18.0"
  }
}
