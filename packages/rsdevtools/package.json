    "@rspack-devtools/core": "workspace:*"
  },
  "devDependencies": {
    "@rspack/core": "^1.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  }
