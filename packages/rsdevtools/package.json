{
  "name": "rsdevtools",
  "version": "0.0.2",
  "type": "module",
  "description": "DevTools for Rspack - Enhance your Rspack DX",
  "license": "MIT",
  "author": "wzc520pyfm",
  "repository": {
    "type": "git",
    "url": "https://github.com/wzc520pyfm/rsdevtools",
    "directory": "packages/rsdevtools"
  },
  "homepage": "https://github.com/wzc520pyfm/rsdevtools#readme",
  "bugs": "https://github.com/wzc520pyfm/rsdevtools/issues",
  "keywords": [
    "rspack",
    "devtools",
